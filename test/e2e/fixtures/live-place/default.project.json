{
	"name": "live-place",
	"globIgnorePaths": ["**/package.json", "**/tsconfig.json"],
	"emitLegacyScripts": false,
	"tree": {
		"$className": "DataModel",
		"ReplicatedStorage": {
			"$className": "ReplicatedStorage",
			"PkgShared": {
				"$path": "out/shared"
			},
			"rbxts_include": {
				"$path": "include",
				"node_modules": {
					"$className": "Folder",
					"@rbxts": {
						"$path": "node_modules/@rbxts"
					},
					"@rbxts-js": {
						"$path": "../../../../../../rojo-sync/@rbxts-js"
					}
				}
			}
		},
		"ServerScriptService": {
			"$className": "ServerScriptService",
			"$properties": {
				"LoadStringEnabled": true
			},
			"PkgServer": {
				"$path": "out/server"
			}
		}
	}
}
