exports[`instrumentation pipeline (integration) > when instrumenting expression-if branches > should produce the expected instrumented source and cov-map > instrumented source 1`] = `
"if _G.__jest_roblox_cov == nil then _G.__jest_roblox_cov = {} end
local __cov_file_key = "expr-if.luau"
if _G.__jest_roblox_cov[__cov_file_key] == nil then _G.__jest_roblox_cov[__cov_file_key] = {} end
if _G.__jest_roblox_cov[__cov_file_key].s == nil then _G.__jest_roblox_cov[__cov_file_key].s = {} end
local __cov_s = _G.__jest_roblox_cov[__cov_file_key].s
for __i = 1, 2 do if __cov_s[__i] == nil then __cov_s[__i] = 0 end end
if _G.__jest_roblox_cov[__cov_file_key].b == nil then _G.__jest_roblox_cov[__cov_file_key].b = {} end
local __cov_b = _G.__jest_roblox_cov[__cov_file_key].b
if __cov_b[1] == nil then __cov_b[1] = {0, 0} end
if __cov_b[2] == nil then __cov_b[2] = {0, 0, 0} end
local function __cov_br(__bi, __ai, ...) __cov_b[__bi][__ai] += 1; return ... end
__cov_s[1] += 1; local x = if true then __cov_br(1, 1, 1) else __cov_br(1, 2, 2)
__cov_s[2] += 1; local y = if false then __cov_br(2, 1, "a") elseif true then __cov_br(2, 2, "b") else __cov_br(2, 3, "c")"
`;

