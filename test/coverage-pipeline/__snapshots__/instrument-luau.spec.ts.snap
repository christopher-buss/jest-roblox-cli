exports[`instrumentation pipeline (integration) > when instrumenting functions > should produce the expected instrumented source and cov-map > instrumented source 1`] = `
"if _G.__jest_roblox_cov == nil then _G.__jest_roblox_cov = {} end
local __cov_file_key = "functions.luau"
if _G.__jest_roblox_cov[__cov_file_key] == nil then _G.__jest_roblox_cov[__cov_file_key] = {} end
if _G.__jest_roblox_cov[__cov_file_key].s == nil then _G.__jest_roblox_cov[__cov_file_key].s = {} end
local __cov_s = _G.__jest_roblox_cov[__cov_file_key].s
for __i = 1, 9 do if __cov_s[__i] == nil then __cov_s[__i] = 0 end end
if _G.__jest_roblox_cov[__cov_file_key].f == nil then _G.__jest_roblox_cov[__cov_file_key].f = {} end
local __cov_f = _G.__jest_roblox_cov[__cov_file_key].f
for __i = 1, 3 do if __cov_f[__i] == nil then __cov_f[__i] = 0 end end
__cov_s[1] += 1; local function greet(name)
    __cov_f[1] += 1; __cov_s[7] += 1; return "Hello, " .. name
end

__cov_s[2] += 1; local handler = function(x)
    __cov_f[2] += 1; __cov_s[8] += 1; return x * 2
end

__cov_s[3] += 1; function globalFunc()
    __cov_f[3] += 1; __cov_s[9] += 1; print("global")
end

__cov_s[4] += 1; greet("world")
__cov_s[5] += 1; handler(5)
__cov_s[6] += 1; globalFunc()"
`;

