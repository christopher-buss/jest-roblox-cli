exports[`instrumentation pipeline (integration) > when instrumenting if/elseif/else branches > should produce the expected instrumented source and cov-map > instrumented source 1`] = `
"if _G.__jest_roblox_cov == nil then _G.__jest_roblox_cov = {} end
local __cov_file_key = "if-else.luau"
if _G.__jest_roblox_cov[__cov_file_key] == nil then _G.__jest_roblox_cov[__cov_file_key] = {} end
if _G.__jest_roblox_cov[__cov_file_key].s == nil then _G.__jest_roblox_cov[__cov_file_key].s = {} end
local __cov_s = _G.__jest_roblox_cov[__cov_file_key].s
for __i = 1, 5 do if __cov_s[__i] == nil then __cov_s[__i] = 0 end end
if _G.__jest_roblox_cov[__cov_file_key].b == nil then _G.__jest_roblox_cov[__cov_file_key].b = {} end
local __cov_b = _G.__jest_roblox_cov[__cov_file_key].b
if __cov_b[1] == nil then __cov_b[1] = {0, 0, 0} end
__cov_s[1] += 1; local x = 1

__cov_s[2] += 1; if x == 1 then
    __cov_b[1][1] += 1; __cov_s[3] += 1; local a = 10
elseif x == 2 then
    __cov_b[1][2] += 1; __cov_s[4] += 1; local b = 20
else
    __cov_b[1][3] += 1; __cov_s[5] += 1; local c = 30
end"
`;
