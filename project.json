{
	"name": "jest-roblox-cli",
	"$schema": "../../node_modules/nx/schemas/project-schema.json",
	"projectType": "application",
	"tags": ["scope:tooling", "type:cli"],
	"sync": {
		"excludeFromReferences": true
	},
	"implicitDependencies": ["jest-roblox-cli-fixture-live-place"],
	"includedScripts": ["!build"],
	"targets": {
		"build": {
			"command": "pnpm build:bundle && tsdown && pnpm build:plugin",
			"options": {
				"cwd": "tools/jest-roblox-cli"
			},
			"outputs": [
				"{projectRoot}/out/**/*.{js,cjs,mjs,jsx,json,d.ts,d.cts,d.mts,luau}{,.map}",
				"{projectRoot}/out/tsconfig.lib.tsbuildinfo",
				"{projectRoot}/dist/*.{mjs,d.mts}{,.map}"
			]
		},
		"lint": {
			"command": "eslint",
			"hasTypeAwareRules": true
		},
		"build:bundle": {
			"command": "pnpm build:bundle",
			"options": {
				"cwd": "tools/jest-roblox-cli"
			},
			"dependsOn": ["weld:build"]
		},
		"test": {
			"command": "tsgo --build --emitDeclarationOnly && vitest run --project unit --coverage && vitest run --project integration",
			"options": {
				"cwd": "tools/jest-roblox-cli"
			},
			"dependsOn": ["build:bundle"]
		},
		"e2e": {
			"command": "vitest run --project e2e",
			"dependsOn": ["build", "^build"],
			"cache": true,
			"inputs": ["default", "^production"],
			"options": {
				"cwd": "tools/jest-roblox-cli"
			}
		},
		"e2e-live-fixture": {
			"command": "pnpm exec rbxtsc -p tsconfig.lib.json --type game",
			"cache": true,
			"inputs": [
				"{projectRoot}/test/e2e/fixtures/live-place/src/**/*",
				"{projectRoot}/test/e2e/fixtures/live-place/tsconfig*.json"
			],
			"outputs": ["{projectRoot}/test/e2e/fixtures/live-place/out"],
			"options": {
				"cwd": "tools/jest-roblox-cli/test/e2e/fixtures/live-place"
			}
		},
		"e2e-live-1of3": {
			"command": "vitest run --project live --shard 1/3",
			"dependsOn": ["build", "^build", "e2e-live-fixture"],
			"cache": true,
			"inputs": [
				"default",
				"^production",
				{
					"env": "JEST_ROBLOX_LIVE"
				},
				{
					"env": "ROBLOX_OPEN_CLOUD_API_KEY"
				},
				{
					"env": "ROBLOX_UNIVERSE_ID"
				},
				{
					"env": "ROBLOX_PLACE_ID"
				}
			],
			"options": {
				"cwd": "tools/jest-roblox-cli"
			}
		},
		"e2e-live-2of3": {
			"command": "vitest run --project live --shard 2/3",
			"dependsOn": ["build", "^build", "e2e-live-fixture"],
			"cache": true,
			"inputs": [
				"default",
				"^production",
				{
					"env": "JEST_ROBLOX_LIVE"
				},
				{
					"env": "ROBLOX_OPEN_CLOUD_API_KEY"
				},
				{
					"env": "ROBLOX_UNIVERSE_ID"
				},
				{
					"env": "ROBLOX_PLACE_ID"
				}
			],
			"options": {
				"cwd": "tools/jest-roblox-cli"
			}
		},
		"e2e-live-3of3": {
			"command": "vitest run --project live --shard 3/3",
			"dependsOn": ["build", "^build", "e2e-live-fixture"],
			"cache": true,
			"inputs": [
				"default",
				"^production",
				{
					"env": "JEST_ROBLOX_LIVE"
				},
				{
					"env": "ROBLOX_OPEN_CLOUD_API_KEY"
				},
				{
					"env": "ROBLOX_UNIVERSE_ID"
				},
				{
					"env": "ROBLOX_PLACE_ID"
				}
			],
			"options": {
				"cwd": "tools/jest-roblox-cli"
			}
		}
	}
}
